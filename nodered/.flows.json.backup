    {
        "id": "beslutning-timer",
        "type": "inject",
        "z": "d2c1c437030fcf3d",
        "name": "Kør hvert 5. minut",
        "repeat": "300",
        "crontab": "",
        "once": true,
        "onceDelay": 5,
        "topic": "",
        "payload": "",
        "payloadType": "date",
        "x": 130,
        "y": 60,
        "wires": [
            [
                "beslutnings-motor"
            ]
        ]
    },
    {
        "id": "beslutnings-motor",
        "type": "function",
        "z": "d2c1c437030fcf3d",
        "name": "Beslutnings-motor",
        "func": "// Tjek override FØRST - kører indtil manuelt stop\nconst overrideAktiv = global.get('override_aktiv') || false;\n\nif (overrideAktiv) {\n    const soc = global.get('batteri_soc') || 0;\n    const sol = global.get('sol_power') || 0;\n    const grid = global.get('grid_power') || 0;\n    node.warn(`🚨 OVERRIDE AKTIV! Tvinger Tesla ladning til 16A`);\n    msg.payload = {\n        growattMode: 'load_first',\n        teslaLad: true,\n        teslaAmp: 16,\n        soc, sol, grid,\n        pris: 0,\n        zone: 'override',\n        beslutning: ['🚨 MANUEL OVERRIDE AKTIV']\n    };\n    return msg;\n}\n\n// Hent aktuelle værdier\nconst soc = global.get('batteri_soc') || 0;\nconst sol = global.get('sol_power') || 0;\nconst grid = global.get('grid_power') || 0;\nconst batteriPower = global.get('batteri_power') || 0;\nconst temp = global.get('batteri_temp') || 0;\nconst nuvaerende = global.get('nuvaerende');\nconst priser = global.get('priser') || [];\nconst loadPower = global.get('load_power') || 0;\n\nif (!nuvaerende) {\n    node.warn('⚠️ Ingen prisdata endnu - afventer');\n    return null;\n}\n\n// Batteri grænser\nconst GROWATT_MIN_SOC = 10;\nconst GROWATT_AFLAD_MIN = 50;\nconst TESLA_MAL = 100;\nconst TESLA_KWH = 60;\nconst TESLA_MAX_KW = 11;\nconst SOL_GRAENSE = 200;\nconst TESLA_MIN_OVERSKUD = 1200;\n\nconst pris = nuvaerende.pris;\nconst zone = nuvaerende.zone;\nconst nu = new Date();\nconst time = nu.getHours();\nconst erHverdag = nu.getDay() >= 1 && nu.getDay() <= 5;\nconst erDyrAften = time >= 16 && time < 21;\nconst erSol = sol > SOL_GRAENSE;\n\n// Sol overskud efter husforbrug\nconst solEfterHus = sol - loadPower;\nconst erSolOverskud = solEfterHus > TESLA_MIN_OVERSKUD;\n\n// Find billigste nattetimer til Tesla\nconst kommende = priser.filter(p => {\n    const t = new Date(p.time);\n    return t > nu;\n}).slice(0, 8);\n\nconst billigsteTimer = [...kommende]\n    .sort((a, b) => a.pris - b.pris)\n    .slice(0, 4)\n    .map(p => new Date(p.time).getHours());\n\nconst erBilligTeslaTime = billigsteTimer.includes(time);\n\n// Tesla deadline check (hverdage kl 03:00-06:00)\nlet tvingTesla = false;\nif (erHverdag && time >= 3 && time < 6) {\n    const carSoc = global.get('car_soc') || 50;\n    const mangler = (TESLA_MAL - carSoc) * (TESLA_KWH / 100);\n    const timerTilbet = 6 - time;\n    const maxKwh = timerTilbet * TESLA_MAX_KW;\n    if (maxKwh < mangler) {\n        tvingTesla = true;\n        node.warn(`⚠️ Tesla kan ikke nå ${TESLA_MAL}%! Mangler ${mangler.toFixed(1)} kWh`);\n    }\n}\n\n// BESLUTNINGER\nlet growattMode = 'load_first'; // DEFAULT altid load first\nlet dischargeMode = 'normal';   // normal = kun aflade hvis dyr tid\nlet teslaLad = false;\nlet teslaAmp = 0;\nlet beslutning = [];\n\n// REGEL 1: Dyre aftentimer → Load first + afladning tilladt\n// Sol + batteri dækker huset, ingen net køb\nif (erDyrAften) {\n    growattMode = 'load_first';\n    dischargeMode = 'aktiv'; // Tillad afladning i dyre timer\n    beslutning.push(`❤️ DYR AFTENTID (${pris} kr) → Load first | Batteri + sol dækker huset`);\n    teslaLad = false;\n}\n\n// REGEL 2: Sol til stede → Load first\nelse if (erSol) {\n    growattMode = 'load_first';\n    dischargeMode = 'stop'; // Batteri skal ikke aflade når sol er til stede\n    beslutning.push(`☀️ Sol (${sol}W) → Load first | Hus: ${loadPower}W | Overskud: ${solEfterHus}W`);\n}\n\n// REGEL 3: Billig time → Load first + lad Tesla hvis batteri OK\nelse if (zone === 'billig') {\n    growattMode = 'load_first';\n    dischargeMode = 'stop';\n    beslutning.push(`💚 BILLIG TIME (${pris} kr) → Load first`);\n    if (soc >= 100 && erBilligTeslaTime) {\n        teslaLad = true;\n        teslaAmp = 10;\n        beslutning.push(`🚗 Tesla lades via net (Growatt 100%)`);\n    }\n}\n\n// REGEL 4: Normal time → Load first\nelse {\n    growattMode = 'load_first';\n    dischargeMode = 'stop';\n    beslutning.push(`🟡 NORMAL TIME (${pris} kr) → Load first`);\n}\n\n// REGEL 5: Sol overskud → lad Tesla\n// KUN hvis: Growatt = 100% OG sol overskud > 1200W\nif (erSolOverskud && soc >= 100) {\n    const teslaAmpBeregnet = Math.floor(solEfterHus / 230);\n    if (teslaAmpBeregnet >= 6) {\n        teslaLad = true;\n        teslaAmp = Math.min(16, teslaAmpBeregnet);\n        beslutning.push(`☀️ Growatt 100% + Sol overskud ${solEfterHus}W → Tesla ${teslaAmp}A`);\n    } else {\n        beslutning.push(`☀️ Sol overskud ${solEfterHus}W → For lidt til Tesla (min 6A = 1380W)`);\n    }\n} else if (erSol && soc < 100) {\n    beslutning.push(`🔋 Growatt ${soc}% → Sol lader batteri først, Tesla venter`);\n}\n\n// REGEL 6: Tving Tesla hvis deadline\nif (tvingTesla && soc > GROWATT_MIN_SOC) {\n    teslaLad = true;\n    teslaAmp = 16;\n    beslutning.push(`🚨 DEADLINE! Tesla tvinges til 16A`);\n}\n\n// REGEL 7: Batteri for varm → advar\nif (temp > 45) {\n    beslutning.push(`🌡️ Growatt batteri for varm (${temp}°C)!`);\n}\n\n// Gem beslutning globalt\nglobal.set('growatt_mode', growattMode);\nglobal.set('discharge_mode', dischargeMode);\nglobal.set('tesla_lad', teslaLad);\nglobal.set('tesla_amp', teslaAmp);\n\nnode.warn(`📊 Growatt: ${soc}% | Sol: ${sol}W | Hus: ${loadPower}W | Overskud: ${solEfterHus}W | Net: ${grid}W | Pris: ${pris} kr (${zone}) | ${erDyrAften ? '🔴 DYR AFTEN' : erSol ? '☀️ SOL' : '🌙 NAT'}`);\nbeslutning.forEach(b => node.warn(b));\n\nmsg.payload = { growattMode, teslaLad, teslaAmp, soc, sol, grid, pris, zone, beslutning };\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 150,
        "y": 160,
        "wires": [
            [
                "udfør-tesla",
                "growatt-styring"
            ]
        ]
    },
    {
        "id": "udfør-tesla",
        "type": "function",
        "z": "d2c1c437030fcf3d",
        "name": "Styr go-e lader",
        "func": "const teslaLad = msg.payload.teslaLad;\nconst teslaAmp = msg.payload.teslaAmp;\nconst carStatus = global.get('go_e_car') || 1;\nconst sidsteTeslaLad = global.get('sidste_tesla_lad');\n\nconst bilTilsluttet = carStatus === 2 || carStatus === 3 || carStatus === 4;\n\nlet eventMsg = null;\n\nif (!bilTilsluttet) {\n    msg.url = `http://192.168.1.222/api/set?frc=0`;\n    node.warn(`🚗 go-e: Ingen bil tilsluttet (car=${carStatus}) - auto mode`);\n\n    // Log hvis bil frakoblet\n    if (sidsteTeslaLad !== false) {\n        global.set('sidste_tesla_lad', false);\n        eventMsg = { payload: { event: 'tesla_ladning', beskrivelse: `King kong frakoblet laderen` }};\n    }\n    return [msg, eventMsg];\n}\n\nif (teslaLad) {\n    msg.url = `http://192.168.1.222/api/set?frc=2&amp=${teslaAmp}`;\n    node.warn(`🚗 go-e: Lader ${teslaAmp}A (car=${carStatus} ✅)`);\n\n    // Log hvis ladning startet\n    if (!sidsteTeslaLad) {\n        global.set('sidste_tesla_lad', true);\n        eventMsg = { payload: { event: 'tesla_ladning', beskrivelse: `King kong startet ladning ${teslaAmp}A` }};\n    }\n} else {\n    msg.url = `http://192.168.1.222/api/set?frc=1`;\n    node.warn(`🚗 go-e: STOP ladning (car=${carStatus})`);\n\n    // Log hvis ladning stoppet\n    if (sidsteTeslaLad) {\n        global.set('sidste_tesla_lad', false);\n        eventMsg = { payload: { event: 'tesla_ladning', beskrivelse: `King kong stoppet ladning` }};\n    }\n}\n\nreturn [msg, eventMsg];",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 380,
        "y": 120,
