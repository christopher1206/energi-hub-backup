    {
        "id": "naeste-begivenhed-api",
        "type": "http in",
        "z": "f8fcc2eca1886938",
        "name": "Næste begivenhed",
        "url": "/api/begivenheder",
        "method": "get",
        "upload": false,
        "skipBodyParsing": false,
        "swaggerDoc": "",
        "x": 190,
        "y": 380,
        "wires": [
            [
                "naeste-begivenhed-handler"
            ]
        ]
    },
    {
        "id": "naeste-begivenhed-handler",
        "type": "function",
        "z": "f8fcc2eca1886938",
        "name": "Byg begivenheder",
        "func": "const nu = new Date();\nconst time = nu.getHours();\nconst min = nu.getMinutes();\nconst soc = global.get('batteri_soc') || 0;\n\n// Beregn næste begivenhed\nlet naeste = [];\n\n// Næste discharge skift\nif (time >= 6 && time < 16) {\n    const diff = 16 - time;\n    naeste.push({ \n        tid: '16:00', \n        besked: '🔋 Dyre timer starter - discharge 100%', \n        minutter: diff * 60 - min \n    });\n} else if (time >= 16 && time < 22) {\n    const diff = 22 - time;\n    naeste.push({ \n        tid: '22:00', \n        besked: '🌙 Nat - discharge 100% fortsætter til 06:00', \n        minutter: diff * 60 - min \n    });\n} else {\n    // Nat 22-06\n    const minutterTil06 = time >= 22 \n        ? (24 - time + 6) * 60 - min \n        : (6 - time) * 60 - min;\n    naeste.push({ \n        tid: '06:00', \n        besked: '☀️ Dag mode - discharge 0% (sol lader batteri)', \n        minutter: minutterTil06\n    });\n}\n\n// Batteri advarsel\nif (soc <= 15) {\n    naeste.unshift({ \n        tid: 'NU', \n        besked: `⚠️ Batteri lavt (${soc}%) - stopper afladning ved 10%`, \n        minutter: 0 \n    });\n}\n\n// Tesla ladning\nconst priser = global.get('priser') || [];\nconst carSoc = global.get('car_soc') || 50;\nconst goECar = global.get('go_e_car') || 1;\n\nif (goECar > 1) {\n    const kommende = priser.filter(p => {\n        const t = new Date(p.time);\n        const h = t.getHours();\n        const erSenAften = t.getDate() === nu.getDate() && h >= 21;\n        const erNat = t.getDate() !== nu.getDate() && h < 6;\n        return (erSenAften || erNat) && t > nu;\n    }).sort((a, b) => a.pris - b.pris);\n\n    if (kommende.length > 0) {\n        const kwhMangler = Math.max(0, (100 - carSoc) * 0.60);\n        const timerNodvendige = Math.ceil(kwhMangler / 11);\n        const billigste = kommende.slice(0, timerNodvendige)\n            .sort((a, b) => new Date(a.time).getTime() - new Date(b.time).getTime());\n        if (billigste.length > 0) {\n            const startTid = new Date(billigste[0].time);\n            const fmt = (d) => d.toLocaleTimeString('da-DK', { hour: '2-digit', minute: '2-digit' });\n            naeste.push({ \n                tid: fmt(startTid), \n                besked: `🚗 Tesla starter ladning (${carSoc}% → 100%)`, \n                minutter: Math.round((startTid.getTime() - nu.getTime()) / 60000) \n            });\n        }\n    }\n}\n\n// Sidst udført\nconst sidst = [\n    { \n        tid: nu.toLocaleTimeString('da-DK', { hour: '2-digit', minute: '2-digit' }), \n        besked: `⚡ Discharge: ${global.get('discharge_rate') || 0}% | Mode: ${global.get('growatt_kommando') || 'Load first'} | Batteri: ${soc}%` \n    },\n];\n\nmsg.payload = { naeste, sidst };\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 440,
        "y": 380,
        "wires": [
            [
                "naeste-begivenhed-svar"
            ]
        ]
