    {
        "id": "byg-rapport",
        "type": "function",
        "z": "ced8b8b6adb174ea",
        "name": "Byg daglig rapport",
        "func": "const soc = global.get('batteri_soc') || 0;\nconst sol = global.get('sol_power') || 0;\nconst nuvaerende = global.get('nuvaerende');\nconst pris = nuvaerende ? nuvaerende.pris : 0;\nconst carSoc = global.get('car_soc') || 50;\nconst zone = nuvaerende ? nuvaerende.zone.toUpperCase() : 'UKENDT';\n\nconst nu = new Date();\nconst dato = nu.toLocaleDateString('da-DK', { weekday: 'long', day: 'numeric', month: 'long' });\n\nmsg.payload = `⚡ <b>Energi Hub - Godmorgen!</b>\\n📅 ${dato}\\n\\n🔋 Growatt batteri: ${soc}%\\n☀️ Sol produktion: ${sol}W\\n💰 Strømpris nu: ${pris} kr/kWh (${zone})\\n🚗 King kong: ${carSoc}%\\n\\nHav en god dag! 🌞`;\nreturn msg;",
        "outputs": 1,
        "x": 440,
        "y": 560,
        "wires": [
            [
                "telegram-send"
            ]
        ]
    },
