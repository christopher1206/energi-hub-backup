    {
        "id": "gem-event",
        "type": "function",
        "z": "d2c1c437030fcf3d",
        "name": "Gem event til InfluxDB",
        "func": "const event = msg.payload.event;\nconst beskrivelse = msg.payload.beskrivelse;\n\nif (!event) return null;\n\nconst lineProtocol = `events,type=${event.replace(/ /g,'_')} beskrivelse=\"${beskrivelse}\"`;\n\nmsg.payload = lineProtocol;\nmsg.headers = {\n    'Authorization': 'Token A-Dni7i_eROyYjhmdcxTc8lLce2gXNzOldul2k2sWY-HMkqZVcE8U9_XvjNqSg4z_0QfbWq6nnTEHCEjtF1K9w==',\n    'Content-Type': 'text/plain'\n};\nmsg.url = 'http://192.168.1.253:8086/api/v2/write?org=energihub&bucket=energi2&precision=s';\nreturn msg;",
        "outputs": 1,
