        "func": "const soc = global.get('batteri_soc') || 0;\nconst sol = global.get('sol_power') || 0;\nconst dischargeRate = global.get('discharge_rate') || 0;\nconst pris = global.get('nuvaerende')?.pris || 0;\n\nmsg.payload = `❤️ Dyre timer startet!\\n\\n🔋 Growatt: ${soc}%\\n⚡ Discharge: ${dischargeRate}%\\n☀️ Sol: ${sol}W\\n💰 Pris: ${pris} kr/kWh\\n\\nSystemet bruger nu batteri + sol til huset!`;\nreturn msg;",
