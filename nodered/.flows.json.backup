    {
        "id": "alarm-check",
        "type": "function",
        "z": "ced8b8b6adb174ea",
        "name": "Alarm check",
        "func": "const soc = global.get('batteri_soc') || 0;\nconst carSoc = global.get('car_soc') || 50;\nconst overrideAktiv = global.get('override_aktiv') || false;\nconst nuvaerende = global.get('nuvaerende');\nconst sol = global.get('sol_power') || 0;\nconst go_e_car = global.get('go_e_car') || 1;\n\nconst beskeder = [];\n\n// Batteri kritisk lavt\nif (soc <= 15) {\n    const sidst = global.get('alarm_batteri_lavt') || 0;\n    if (Date.now() - sidst > 3600000) { // Max 1 gang per time\n        beskeder.push(`⚠️ Growatt batteri LAVT: ${soc}%`);\n        global.set('alarm_batteri_lavt', Date.now());\n    }\n}\n\n// Batteri fuldt - klar til dyre timer\nif (soc >= 95) {\n    const sidst = global.get('alarm_batteri_fuld') || 0;\n    if (Date.now() - sidst > 7200000) { // Max 1 gang per 2 timer\n        beskeder.push(`✅ Growatt batteri FULDT: ${soc}% - Klar til dyre timer!`);\n        global.set('alarm_batteri_fuld', Date.now());\n    }\n}\n\n// Bil tilsluttet\nif (go_e_car === 2 || go_e_car === 3) {\n    const sidst = global.get('alarm_bil_tilsluttet') || 0;\n    if (Date.now() - sidst > 3600000) {\n        beskeder.push(`🚗 King kong tilsluttet laderen!`);\n        global.set('alarm_bil_tilsluttet', Date.now());\n    }\n}\n\n// Høj sol produktion\nif (sol > 5000) {\n    const sidst = global.get('alarm_sol_hoj') || 0;\n    if (Date.now() - sidst > 7200000) {\n        beskeder.push(`☀️ Høj sol produktion: ${sol}W!`);\n        global.set('alarm_sol_hoj', Date.now());\n    }\n}\n\nif (beskeder.length === 0) return null;\n\nmsg.payload = beskeder.join('\\n');\nreturn msg;",
        "outputs": 1,
        "x": 190,
        "y": 440,
        "wires": [
            [
                "telegram-send"
            ]
        ]
    },
