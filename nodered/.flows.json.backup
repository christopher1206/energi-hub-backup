    {
        "id": "beregn-zoner",
        "type": "function",
        "z": "f8fcc2eca1886938",
        "name": "Beregn pris-zoner",
        "func": "// Tjek for API fejl eller tom data\nif (msg.payload.statusCode) {\n    node.warn(`⚠️ API fejl: ${msg.payload.message}`);\n    return null;\n}\n\nconst records = Array.isArray(msg.payload) ? msg.payload : msg.payload.records;\n\nif (!records || records.length === 0) {\n    node.warn('⚠️ Tom data modtaget - sandsynligvis i morgens priser ikke klar endnu');\n    return null;\n}\n\n// Ryd gammel cache hvis den ikke har spotpris felt\nconst eksisterendeCheck = global.get('priser_raw') || [];\nif (eksisterendeCheck.length > 0 && !eksisterendeCheck[0].spotpris) {\n    global.set('priser_raw', []);\n    node.warn('🔄 Rydder gammel priscache - opdaterer med afgifter');\n}\n\n// Afgifter baseret på tidspunkt (Radius C zone)\nconst getFastTillæg = (hour) => {\n    if (hour >= 0 && hour < 6)   return 0.287;\n    if (hour >= 6 && hour < 17)  return 0.353;\n    if (hour >= 17 && hour < 21) return 0.672;\n    return 0.353;\n};\n\n// Konverter til DKK/kWh inkl. afgifter\nconst nyePriser = records.map(r => {\n    const hour = new Date(r.time_start).getHours();\n    const spotpris = parseFloat(r.DKK_per_kWh.toFixed(4));\n    const realPris = parseFloat((spotpris + getFastTillæg(hour)).toFixed(4));\n    return {\n        time: r.time_start,\n        pris: realPris,\n        spotpris: spotpris,\n        hour: hour\n    };\n});\n\n// Merge med eksisterende priser (behold begge dage)\nconst eksisterende = global.get('priser_raw') || [];\n\n// Fjern dubletter baseret på time\nconst merged = [...eksisterende];\nnyePriser.forEach(ny => {\n    const findes = merged.find(e => e.time === ny.time);\n    if (!findes) merged.push(ny);\n});\n\n// Sorter efter tid\nmerged.sort((a, b) => new Date(a.time).getTime() - new Date(b.time).getTime());\n\n// Gem rådata til næste merge\nglobal.set('priser_raw', merged);\n\nnode.warn(`📦 Rådata: ${merged.length} timer total`);\n\n// Dynamiske zoner baseret på alle kendte priser\nconst sorteret = [...merged].sort((a, b) => a.pris - b.pris);\nconst antalTimer = sorteret.length;\nconst billigGraense = sorteret[Math.floor(antalTimer / 3)].pris;\nconst dyrGraense = sorteret[Math.floor(antalTimer * 2 / 3)].pris;\n\nconst markeretPriser = merged.map(p => ({\n    ...p,\n    zone: p.pris <= billigGraense ? 'billig' : p.pris >= dyrGraense ? 'dyr' : 'normal'\n}));\n\n// Find nuværende time\nconst nu = new Date();\nconst nuvaerende = markeretPriser.find(p => {\n    const t = new Date(p.time);\n    return t.getHours() === nu.getHours() &&\n           t.getDate() === nu.getDate() &&\n           t.getMonth() === nu.getMonth();\n});\n\nif (!nuvaerende) {\n    node.warn(`⚠️ Ingen pris for nuværende time`);\n}\n\n// Tjek om vi har nattetimer\nconst harNatTimer = markeretPriser.some(p => {\n    const t = new Date(p.time);\n    return t > nu && t.getDate() !== nu.getDate() && t.getHours() < 6;\n});\n\n// Gem globalt\nglobal.set('priser', markeretPriser);\nglobal.set('billigGraense', billigGraense);\nglobal.set('dyrGraense', dyrGraense);\nglobal.set('nuvaerende', nuvaerende);\nglobal.set('har_nok_prisdata', harNatTimer);\n\nnode.warn(`✅ Priser: ${markeretPriser.length} timer | Nat: ${harNatTimer ? '✅' : '⏳ venter'}`);\nnode.warn(`💚 Billig < ${billigGraense} kr/kWh`);\nnode.warn(`❤️ Dyr > ${dyrGraense} kr/kWh`);\nif (nuvaerende) {\n    node.warn(`⚡ Nu: ${nuvaerende.pris} kr/kWh (spot: ${nuvaerende.spotpris}) - ${nuvaerende.zone.toUpperCase()}`);\n}\n\nmsg.payload = { priser: markeretPriser, billigGraense, dyrGraense, nuvaerende, harNatTimer };\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 810,
        "y": 100,
        "wires": [
            [
                "debug-priser",
                "gem-influxdb"
            ]
        ]
    },
