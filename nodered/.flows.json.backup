        "id": "byg-06-notif",
        "type": "function",
        "z": "ced8b8b6adb174ea",
        "name": "Byg 06:00 besked",
        "func": "const soc = global.get('batteri_soc') || 0;\nconst carSoc = global.get('car_soc') || 50;\nconst sol = global.get('sol_power') || 0;\nconst nuvaerende = global.get('nuvaerende');\nconst pris = nuvaerende ? nuvaerende.pris : 0;\n\nconst bilKlar = carSoc >= 95 ? '✅' : '⚠️';\n\nmsg.payload = `🌅 God morgen Christopher!\\n\\n${bilKlar} King kong: ${carSoc}%\\n🔋 Growatt: ${soc}%\\n☀️ Sol: ${sol}W\\n💰 Pris nu: ${pris} kr/kWh\\n\\n${carSoc < 95 ? '⚠️ Bilen er ikke fuldt opladet!' : '✅ Bilen er klar til turen!'}`;\nreturn msg;",
        "outputs": 1,
