    {
        "id": "growatt-styring",
        "type": "function",
        "z": "d2c1c437030fcf3d",
        "name": "Growatt kommando",
        "func": "const GROWATT_MIN_SOC = 10;\nconst growattMode = msg.payload.growattMode;\nconst soc = msg.payload.soc;\nconst time = new Date().getHours();\n\n// ALTID Load first\nconst workMode = 'Load first';\n\n// Discharge logik\nlet dischargeRate = 0;\nlet dischargeAarsag = '';\n\nif (soc <= GROWATT_MIN_SOC) {\n    dischargeRate = 0;\n    dischargeAarsag = `Batteri for lavt (${soc}%)`;\n    node.warn(`🔋 Batteri for lavt (${soc}%) → Ingen afladning`);\n} else if (time >= 6 && time < 16) {\n    dischargeRate = 0;\n    dischargeAarsag = `Dag mode (${time}:00)`;\n    node.warn(`☀️ Dag (06-16) → Spar batteri, sol lader`);\n} else {\n    dischargeRate = 100;\n    dischargeAarsag = `Aften/nat mode (${time}:00)`;\n    node.warn(`🔋 Aften/nat (16-06) → Afladning 100%`);\n}\n\nglobal.set('growatt_kommando', workMode);\nglobal.set('discharge_rate', dischargeRate);\n\nnode.warn(`⚡ Growatt: ${workMode} | Discharge: ${dischargeRate}%`);\n\n// Log event hvis discharge ændret sig\nconst sidsteDischarge = global.get('sidste_discharge_rate');\nlet eventMsg = null;\n\nif (sidsteDischarge !== dischargeRate) {\n    global.set('sidste_discharge_rate', dischargeRate);\n    eventMsg = {\n        payload: {\n            event: 'discharge_skift',\n            beskrivelse: `Discharge ${sidsteDischarge !== undefined ? sidsteDischarge : '?'}% → ${dischargeRate}% (${dischargeAarsag})`\n        }\n    };\n    node.warn(`📝 Event: Discharge skift ${sidsteDischarge}% → ${dischargeRate}%`);\n}\n\nmsg.payload = workMode;\nmsg.topic = 'solar_assistant/inverter_1/work_mode_priority/set';\n\nmsg.discharge = {\n    payload: dischargeRate.toString(),\n    topic: 'solar_assistant/inverter_1/free_mode_discharge_rate/set'\n};\n\nreturn [msg, eventMsg];",
