    {
        "id": "bil-tilsluttet-check",
        "type": "function",
        "z": "ced8b8b6adb174ea",
        "name": "Bil tilsluttet check",
        "func": "const goECar = global.get('go_e_car') || 1;\nconst sidsteCar = global.get('go_e_car_sidst') || 1;\n\n// Bil netop tilsluttet?\nif (goECar > 1 && sidsteCar === 1) {\n    const carSoc = global.get('car_soc') || 50;\n    const sol = global.get('sol_power') || 0;\n    const soc = global.get('batteri_soc') || 0;\n    msg.payload = `🚗 King kong er tilsluttet laderen!\\n\\n🔋 Bil SOC: ${carSoc}%\\n🔋 Growatt: ${soc}%\\n☀️ Sol: ${sol}W\\n\\n${soc >= 100 && sol > 1200 ? '⚡ Lader via sol overskud!' : '⏳ Venter på billigste ladetimer'}`;\n    global.set('go_e_car_sidst', goECar);\n    return msg;\n}\n\nglobal.set('go_e_car_sidst', goECar);\nreturn null;",
        "outputs": 1,
        "x": 1210,
        "y": 760,
        "wires": [
            [
                "969ad2da2c958f57"
            ]
        ]
    },
