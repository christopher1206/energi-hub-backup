        "z": "ced8b8b6adb174ea",
        "name": "Byg statistik",
        "func": "const pvEnergi = global.get('pv_energy_total') || 0;\nconst gridInd = global.get('grid_energy_in') || 0;\nconst gridUd = global.get('grid_energy_out') || 0;\nconst loadEnergi = global.get('load_energy_total') || 0;\nconst batInd = global.get('battery_energy_in') || 0;\nconst batUd = global.get('battery_energy_out') || 0;\nconst soc = global.get('batteri_soc') || 0;\nconst sol = global.get('sol_power') || 0;\nconst grid = global.get('grid_power') || 0;\nconst load = global.get('load_power') || 0;\nconst nuvaerende = global.get('nuvaerende');\nconst pris = nuvaerende ? nuvaerende.pris : 0;\nconst carSoc = global.get('car_soc') || 50;\n\n// Besparelsesberegning\n// Gennemsnitlig dansk elpris inkl afgifter ~2.50 kr/kWh\nconst gennemsnitsElpris = 2.50;\nconst sparetTotal = parseFloat(((pvEnergi - gridInd) * gennemsnitsElpris).toFixed(2));\n\n// Selvforsyningsgrad\nconst selvforsyning = loadEnergi > 0 ? parseFloat(((1 - gridInd / loadEnergi) * 100).toFixed(1)) : 0;\n\n// go-e data\nconst goEWh = global.get('go_e_wh') || 0;\nconst goEAmp = global.get('go_e_amp') || 0;\nconst goECar = global.get('go_e_car') || 1;\n\nmsg.payload = {\n    // Sol\n    pv_energy_total: pvEnergi,\n    sol_power_nu: sol,\n    \n    // Net\n    grid_energy_in: gridInd,\n    grid_energy_out: gridUd,\n    grid_power_nu: grid,\n    \n    // Hus\n    load_energy_total: loadEnergi,\n    load_power_nu: load,\n    \n    // Batteri\n    battery_energy_in: batInd,\n    battery_energy_out: batUd,\n    batteri_soc: soc,\n    \n    // Tesla\n    car_soc: carSoc,\n    go_e_wh_total: goEWh,\n    go_e_amp: goEAmp,\n    go_e_car: goECar,\n    \n    // Beregninger\n    sparet_total: sparetTotal,\n    selvforsyning: selvforsyning,\n    pris_nu: pris,\n    \n    timestamp: new Date().toISOString()\n};\nreturn msg;",
        "outputs": 1,
        "x": 420,
        "y": 660,
        "wires": [
            [
                "statistik-svar"
            ]
        ]
    },
    {
        "id": "statistik-svar",
