        "func": "msg.payload = null;\nmsg.headers = {\n    'Authorization': 'Token A-Dni7i_eROyYjhmdcxTc8lLce2gXNzOldul2k2sWY-HMkqZVcE8U9_XvjNqSg4z_0QfbWq6nnTEHCEjtF1K9w==',\n    'Content-Type': 'application/vnd.flux',\n    'Accept': 'application/csv'\n};\nmsg.url = 'http://192.168.1.253:8086/api/v2/query?org=energihub';\nmsg.method = 'POST';\nmsg.payload = `from(bucket: \"energi2\") |> range(start: -30d) |> filter(fn: (r) => r._measurement == \"events\") |> sort(columns: [\"_time\"], desc: true) |> limit(n: 50)`;\nreturn msg;",
