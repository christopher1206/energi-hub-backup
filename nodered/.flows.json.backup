    {
        "id": "bil-soc-handler",
        "type": "function",
        "z": "ced8b8b6adb174ea",
        "name": "Gem bil SOC",
        "func": "const soc = parseFloat(msg.payload.soc);\n\nif (isNaN(soc) || soc < 0 || soc > 100) {\n    msg.payload = { success: false, besked: 'Ugyldig SOC værdi' };\n    return msg;\n}\n\nglobal.set('car_soc', soc);\nglobal.set('car_soc_opdateret', new Date().toISOString());\n\nnode.warn(`🚗 Bil SOC sat til: ${soc}%`);\nmsg.payload = { success: true, soc, besked: `Bil SOC sat til ${soc}%` };\nreturn msg;",
        "outputs": 1,
        "x": 400,
        "y": 140,
        "wires": [
            [
                "bil-soc-svar"
            ]
        ]
    },
