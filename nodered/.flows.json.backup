        "func": "const car = msg.payload.car || 0;\nconst amp = msg.payload.amp || 0;\nconst wh = msg.payload.wh || 0;\n\nglobal.set('go_e_car', car);\nglobal.set('go_e_amp', amp);\nglobal.set('go_e_wh', wh);\n\nnode.warn(`🔌 go-e: car=${car} | amp=${amp}A | wh=${wh}`);\nreturn null;",
