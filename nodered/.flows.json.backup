    {
        "id": "c6e3748f632ca8c5",
        "type": "function",
        "z": "f8fcc2eca1886938",
        "name": "Byg API URL",
        "func": "const nu = new Date();\nconst år = nu.getFullYear();\nconst måned = String(nu.getMonth() + 1).padStart(2, '0');\nconst dag = String(nu.getDate()).padStart(2, '0');\n\nconst imorgen = new Date(nu);\nimorgen.setDate(imorgen.getDate() + 1);\nconst imorgeMåned = String(imorgen.getMonth() + 1).padStart(2, '0');\nconst imorgenDag = String(imorgen.getDate()).padStart(2, '0');\n\nnode.warn(`Henter priser for: ${dag}/${måned} og ${imorgenDag}/${imorgeMåned}`);\n\n// Send to beskeder - én for hver dag\nconst msg2 = { ...msg };\nmsg.url = `https://www.elprisenligenu.dk/api/v1/prices/${år}/${måned}-${dag}_DK1.json`;\nmsg.dag = 'idag';\nmsg2.url = `https://www.elprisenligenu.dk/api/v1/prices/${år}/${imorgeMåned}-${imorgenDag}_DK1.json`;\nmsg2.dag = 'imorgen';\n\nreturn [msg, msg2];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 350,
        "y": 100,
        "wires": [
            [
                "2192ee2761c874e0"
            ],
            [
                "2192ee2761c874e0"
            ]
        ]
    },
    {
        "id": "8ab9b4e3c8873943",
        "type": "function",
        "z": "f8fcc2eca1886938",
        "name": "Tjek prisdata",
        "func": "const nu = new Date();\nconst eksisterendePriser = global.get('priser') || [];\n\n// Find gyldige fremtidige ladetimer (16:00 i dag → 06:00 i morgen)\nconst gyldigeLadeTimer = eksisterendePriser.filter(p => {\n    const t = new Date(p.time);\n    if (t <= nu) return false;\n    const erAftenIdag = t.getDate() === nu.getDate() && t.getHours() >= 16;\n    const erNatImorgen = t.getDate() !== nu.getDate() && t.getHours() < 6;\n    return erAftenIdag || erNatImorgen;\n});\n\n// Har vi nattetimer (00:00-06:00 i morgen)?\nconst harNatTimer = gyldigeLadeTimer.some(p => {\n    const t = new Date(p.time);\n    return t.getDate() !== nu.getDate() && t.getHours() < 6;\n});\n\n// Har vi aftentimer (16:00-23:59 i dag)?\nconst harAftenTimer = gyldigeLadeTimer.some(p => {\n    const t = new Date(p.time);\n    return t.getDate() === nu.getDate() && t.getHours() >= 16;\n});\n\nnode.warn(`📊 Ladetimer: ${gyldigeLadeTimer.length} | Aften: ${harAftenTimer ? '✅' : '❌'} | Nat: ${harNatTimer ? '✅' : '❌'}`);\n\n// Vi har komplet data hvis vi har BÅDE aften og nattetimer\nif (gyldigeLadeTimer.length >= 14 && harAftenTimer && harNatTimer) {\n    node.warn('✅ Prisdata komplet - ingen API kald nødvendigt');\n    global.set('har_nok_prisdata', true);\n    return null; // Stop her!\n}\n\nnode.warn('⚠️ Mangler prisdata - henter fra API');\nglobal.set('har_nok_prisdata', false);\nreturn msg; // Fortsæt til API hentning",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 390,
        "y": 260,
        "wires": [
            [
                "c6e3748f632ca8c5"
            ]
        ]
    },
